# SOPDS Configuration File
# Simple OPDS Catalog Server

database:
  host: localhost
  port: 5432
  name: sopds
  user: sopds
  password: sopds
  sslmode: disable

library:
  # Path to your book collection
  root: /
  # File formats to index
  formats:
    - .fb2
    - .epub
    - .mobi
    - .pdf
    - .djvu
  # Scan inside ZIP archives
  scan_zip: true
  # Rescan ZIP files on each scan (slower but catches changes)
  rescan_zip: false

server:
  bind: 0.0.0.0
  port: 8081                       # matches docker-compose.example.yml's port mapping
                                   # (the original Python SOPDS used 8789; safe to change)
  opds_prefix: /opds
  web_prefix: /web
  auth:
    enabled: false                  # set to true and list users below to require login
    users: []                       # empty list = no users (when auth.enabled = false)
    # users:                        # uncomment + populate when auth.enabled = true:
    #   - username: "alice"         # quote values to avoid YAML alias-ref errors
    #     password: "change-me"     # (bare `*****` is parsed as YAML alias and fails)
    #   - username: "bob"
    #     password: "also-change-me"

scanner:
  # Number of parallel workers for scanning
  workers: 4
  # Cron schedule for automatic scanning (empty to disable)
  schedule: "" # "0 3 * * *"
  # Run scan when server starts
  on_start: false
  # Duplicate detection: none, normal (title+authors), strong (title+format+size), clear
  duplicates: normal
  pid_file: /tmp/sopds.pid

site:
  id: "urn:sopds:catalog"
  title: "SOPDS Library"
  subtitle: "Simple OPDS Catalog"
  author: "Admin"
  url: "http://localhost:8081"
  email: "admin@example.com"
  main_title: "Library Catalog"

logging:
  level: info
  file: /var/log/sopds/sopds.log

converters:
  # Path to FB2 to EPUB converter (optional)
  fb2toepub: "ebook-convert"              # Not used (pure Go)
  # Path to FB2 to MOBI converter (optional)
  fb2tomobi: "ebook-convert" # Calibre path
  # Temporary directory for conversions
  temp_dir: /tmp

# SMTP — for email verification on signup and password reset emails.
# Optional; sopds-go runs fine without it but new users won't get a
# verification link (and password-reset feature is unavailable).
#
# Common provider settings (port + TLS):
#   Gmail SMTP:    smtp.gmail.com         587  STARTTLS  (app password required)
#   Resend:        smtp.resend.com        465  TLS       (API key as password)
#   Mailgun:       smtp.mailgun.org       587  STARTTLS
#   AWS SES:       email-smtp.<region>... 587  STARTTLS
#   Local relay:   localhost              25   neither
smtp:
  enabled: false                           # flip to true after filling in below
  host: "smtp.gmail.com"
  port: 587
  username: "you@gmail.com"
  password: "<app-password-or-API-key>"   # NEVER your real Gmail password — use an app password
  from: "SOPDS Library <noreply@example.com>"
  use_tls: false                           # set true for port 465 (implicit TLS)
  use_starttls: true                       # set true for port 587 (STARTTLS upgrade)

# JWT secret for signing email-verification and password-reset tokens.
# REQUIRED for the email flows to work. Generate any random string;
# rotate it to invalidate all outstanding verification/reset tokens.
# Example: `openssl rand -hex 32`.
jwt_secret: "change-me-to-a-long-random-string"
